# Copy this file to `.env` and fill in the values.
# NEVER commit your real .env — it is git-ignored.

# Deployer private key (hex). Use a throwaway / hot wallet, not your main one.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Optional: address that receives the full initial supply.
# Defaults to the deployer address if left unset.
# TOKEN_RECIPIENT=0x0000000000000000000000000000000000000000

# RPC endpoints
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# BaseScan API key for source verification — https://basescan.org/myapikey
BASESCAN_API_KEY=
